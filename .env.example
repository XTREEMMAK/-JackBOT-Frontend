# JackBOT Frontend Environment Variables - Example
# Copy this file to .env and .env.production and fill in your values

# Webhook Configuration
WEBHOOK_URL=https://your-webhook-url-here.com/webhook/your-webhook-id

# Application Configuration
PUBLIC_APP_NAME=Jack BOT Agent
PUBLIC_APP_DESCRIPTION=Your friendly pirate chat assistant
PUBLIC_THEME_COLOR=#f0b034

# Environment
NODE_ENV=development